{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Baselode Viewer",
  "version": "0.1.0",
  "identifier": "ai.darkmine.baselode-viewer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Baselode Viewer",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "app", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Darkmine Pty Ltd",
    "category": "DeveloperTool",
    "shortDescription": "Drilling-data viewer powered by the baselode library.",
    "longDescription": "Baselode Viewer is a desktop viewer for drilling exploration data. Open a project folder of CSVs and explore the holes on a map, in 3D, and as strip logs."
  }
}
